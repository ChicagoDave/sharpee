# Public-hoist @sharpee/* and the lz-string vendored baseline entry so
# Node's ESM resolver can find every Story Runtime Baseline (ADR-178)
# package from arbitrary paths during dev — e.g., the bundle-cache
# directory the engine writes story.js into. The Docker runtime image
# already gets a flat node_modules via `pnpm deploy --legacy`; this
# config makes the dev workspace match that shape.
public-hoist-pattern[]=@sharpee/*
public-hoist-pattern[]=lz-string
