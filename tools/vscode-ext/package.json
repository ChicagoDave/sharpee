{
  "name": "sharpee-vscode",
  "displayName": "Sharpee — Interactive Fiction Authoring",
  "description": "Syntax highlighting, snippets, and tooling for Sharpee interactive fiction projects",
  "version": "0.5.0",
  "publisher": "chicagodave",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:sharpee-transcript",
    "workspaceContains:**/*.transcript",
    "onCommand:sharpee.newStory",
    "onCommand:sharpee.buildStory",
    "onCommand:sharpee.playStory",
    "onCommand:sharpee.playInBrowser",
    "onView:sharpee.worldExplorer",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sharpee-transcript",
        "aliases": [
          "Sharpee Transcript",
          "transcript"
        ],
        "extensions": [
          ".transcript"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sharpee-transcript",
        "scopeName": "source.sharpee-transcript",
        "path": "./syntaxes/sharpee-transcript.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sharpee-explorer",
          "title": "Sharpee",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "sharpee-explorer": [
        {
          "id": "sharpee.worldExplorer",
          "name": "World Explorer",
          "contextualTitle": "Sharpee World Explorer"
        }
      ]
    },
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/sharpee-story.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "sharpee",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "The sharpee command to run (e.g., 'test')"
          },
          "file": {
            "type": "string",
            "description": "The transcript file to test"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "sharpee-transcript",
        "owner": "sharpee",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^\\s+Line (\\d+):\\s+(.+)$",
            "line": 1,
            "message": 2
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Testing:",
          "endsPattern": "^(PASS|FAIL|Results:)"
        }
      }
    ],
    "commands": [
      {
        "command": "sharpee.runTranscript",
        "title": "Sharpee: Run Transcript Test",
        "icon": "$(play)"
      },
      {
        "command": "sharpee.newStory",
        "title": "Sharpee: New Story"
      },
      {
        "command": "sharpee.buildStory",
        "title": "Sharpee: Build Story",
        "icon": "$(tools)"
      },
      {
        "command": "sharpee.playStory",
        "title": "Sharpee: Play Story",
        "icon": "$(terminal)"
      },
      {
        "command": "sharpee.playInBrowser",
        "title": "Sharpee: Play in Browser",
        "icon": "$(globe)"
      },
      {
        "command": "sharpee.refreshWorldExplorer",
        "title": "Sharpee: Refresh World Explorer",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == sharpee-transcript",
          "command": "sharpee.runTranscript",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "sharpee.refreshWorldExplorer",
          "when": "view == sharpee.worldExplorer",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sharpee.runTranscript",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "resourceLangId == sharpee-transcript"
      },
      {
        "command": "sharpee.buildStory",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      }
    ],
    "configurationDefaults": {
      "[sharpee-transcript]": {
        "editor.foldingStrategy": "auto"
      }
    },
    "configuration": {
      "title": "Sharpee",
      "properties": {
        "sharpee.cliBundlePath": {
          "type": "string",
          "default": "dist/cli/sharpee.js",
          "description": "Path to the Sharpee CLI bundle relative to the workspace root"
        },
        "sharpee.storyId": {
          "type": "string",
          "default": "",
          "description": "Story ID to build and play (e.g., 'dungeo'). If empty, auto-detects from stories/ directory."
        },
        "sharpee.buildScript": {
          "type": "string",
          "default": "./build.sh",
          "description": "Path to the build script relative to the workspace root"
        },
        "sharpee.enableEntityAutocomplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable entity ID autocomplete in TypeScript story files (room IDs, entity IDs, NPC IDs)"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
