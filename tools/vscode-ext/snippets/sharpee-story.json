{
  "Sharpee: Room": {
    "prefix": "room",
    "body": [
      "function create${1:Room}(world: WorldModel): IFEntity {",
      "\tconst room = world.createEntity('${2:Room Name}', EntityType.ROOM);",
      "",
      "\troom.add(new RoomTrait({",
      "\t\texits: {},",
      "\t\tisDark: ${3|false,true|},",
      "\t\tisOutdoors: ${4|false,true|}",
      "\t}));",
      "",
      "\troom.add(new IdentityTrait({",
      "\t\tname: '${2:Room Name}',",
      "\t\taliases: [${5:''}],",
      "\t\tdescription: '${6:A room.}',",
      "\t\tproperName: true,",
      "\t\tarticle: ''",
      "\t}));",
      "",
      "\treturn room;",
      "}"
    ],
    "description": "Create a new room entity with RoomTrait and IdentityTrait"
  },

  "Sharpee: Object": {
    "prefix": "object",
    "body": [
      "function create${1:Item}(world: WorldModel): IFEntity {",
      "\tconst item = world.createEntity('${2:item name}', EntityType.ITEM);",
      "",
      "\titem.add(new IdentityTrait({",
      "\t\tname: '${2:item name}',",
      "\t\taliases: [${3:''}],",
      "\t\tdescription: '${4:An item.}',",
      "\t\tproperName: false,",
      "\t\tarticle: '${5|a,an,the,some|}',",
      "\t\tweight: ${6:5}",
      "\t}));",
      "",
      "\treturn item;",
      "}"
    ],
    "description": "Create a new item entity with IdentityTrait"
  },

  "Sharpee: Container": {
    "prefix": "container",
    "body": [
      "function create${1:Container}(world: WorldModel): IFEntity {",
      "\tconst container = world.createEntity('${2:container name}', EntityType.CONTAINER);",
      "",
      "\tcontainer.add(new IdentityTrait({",
      "\t\tname: '${2:container name}',",
      "\t\taliases: [${3:''}],",
      "\t\tdescription: '${4:A container.}',",
      "\t\tproperName: false,",
      "\t\tarticle: '${5|a,an,the|}'",
      "\t}));",
      "",
      "\tcontainer.add(new ContainerTrait({",
      "\t\tcapacity: {",
      "\t\t\tmaxItems: ${6:10}",
      "\t\t}",
      "\t}));",
      "",
      "\tcontainer.add(new OpenableTrait({",
      "\t\tisOpen: ${7|false,true|}",
      "\t}));",
      "",
      "\treturn container;",
      "}"
    ],
    "description": "Create a container entity with ContainerTrait and OpenableTrait"
  },

  "Sharpee: Door": {
    "prefix": "door",
    "body": [
      "function create${1:Door}(world: WorldModel): IFEntity {",
      "\tconst door = world.createEntity('${2:door name}', EntityType.SCENERY);",
      "",
      "\tdoor.add(new IdentityTrait({",
      "\t\tname: '${2:door name}',",
      "\t\taliases: [${3:'door'}],",
      "\t\tdescription: '${4:A door.}',",
      "\t\tproperName: false,",
      "\t\tarticle: '${5|a,an,the|}'",
      "\t}));",
      "",
      "\tdoor.add(new OpenableTrait({ isOpen: false }));",
      "\tdoor.add(new SceneryTrait());",
      "\tdoor.add(new LockableTrait({ isLocked: ${6|true,false|} }));",
      "",
      "\treturn door;",
      "}",
      "",
      "// Connect rooms through door:",
      "// RoomBehavior.setExit(roomA, Direction.${7:NORTH}, roomBId, door.id);",
      "// RoomBehavior.setExit(roomB, Direction.${8:SOUTH}, roomAId, door.id);"
    ],
    "description": "Create a door entity with OpenableTrait and LockableTrait"
  },

  "Sharpee: Actor": {
    "prefix": "actor",
    "body": [
      "function create${1:Npc}(world: WorldModel): IFEntity {",
      "\tconst npc = world.createEntity('${2:npc name}', EntityType.ACTOR);",
      "",
      "\tnpc.add(new IdentityTrait({",
      "\t\tname: '${2:npc name}',",
      "\t\taliases: [${3:''}],",
      "\t\tdescription: '${4:An NPC.}',",
      "\t\tproperName: false,",
      "\t\tarticle: '${5|a,an,the|}'",
      "\t}));",
      "",
      "\tnpc.add(new ActorTrait({",
      "\t\tisPlayer: false",
      "\t}));",
      "",
      "\tnpc.add(new NpcTrait({",
      "\t\tbehaviorId: '${6:npc-behavior-id}',",
      "\t\tisHostile: false,",
      "\t\tcanMove: ${7|false,true|}",
      "\t}));",
      "",
      "\treturn npc;",
      "}"
    ],
    "description": "Create an NPC entity with ActorTrait and NpcTrait"
  },

  "Sharpee: Action": {
    "prefix": "action",
    "body": [
      "import { Action, ActionContext, ValidationResult } from '@sharpee/stdlib';",
      "import { ISemanticEvent } from '@sharpee/core';",
      "",
      "export const ${1:ACTION_ID} = '${2:story.action.name}';",
      "",
      "export const ${3:myAction}: Action = {",
      "\tid: ${1:ACTION_ID},",
      "\tgroup: '${4:manipulation}',",
      "",
      "\tvalidate(context: ActionContext): ValidationResult {",
      "\t\t${5:// Validate preconditions}",
      "\t\treturn { valid: true };",
      "\t},",
      "",
      "\texecute(context: ActionContext): void {",
      "\t\t${6:// Perform state mutations}",
      "\t},",
      "",
      "\treport(context: ActionContext): ISemanticEvent[] {",
      "\t\treturn [context.event('${7:game.message}', {",
      "\t\t\tmessageId: '${8:message.id}'",
      "\t\t})];",
      "\t},",
      "",
      "\tblocked(context: ActionContext, result: ValidationResult): ISemanticEvent[] {",
      "\t\treturn [context.event('${9:game.message}', {",
      "\t\t\tmessageId: result.error || '${10:message.blocked}'",
      "\t\t})];",
      "\t}",
      "};"
    ],
    "description": "Create a four-phase action (validate/execute/report/blocked)"
  },

  "Sharpee: Grammar (forAction)": {
    "prefix": "grammar",
    "body": [
      "grammar",
      "\t.forAction('${1:if.action.name}')",
      "\t.verbs([${2:'verb1', 'verb2'}])",
      "\t.pattern('${3::target}')",
      "\t.where('${4:target}', (scope) => scope.${5|visible,touchable,reachable|}())",
      "\t.build();"
    ],
    "description": "Register a grammar pattern using the action-centric .forAction() API"
  },

  "Sharpee: Grammar (define)": {
    "prefix": "grammar-define",
    "body": [
      "grammar",
      "\t.define('${1:verb :target}')",
      "\t.mapsTo(${2:ACTION_ID})",
      "\t.withPriority(${3:150})",
      "\t.build();"
    ],
    "description": "Register a grammar pattern using .define() for phrasal verbs or story-specific commands"
  },

  "Sharpee: Message": {
    "prefix": "message",
    "body": [
      "language.addMessage('${1:message.id}', '${2:Message text with {param}.}');"
    ],
    "description": "Register a message with the language provider"
  },

  "Sharpee: Daemon": {
    "prefix": "daemon",
    "body": [
      "import { Daemon, SchedulerContext, ISchedulerService } from '@sharpee/plugin-scheduler';",
      "import { ISemanticEvent } from '@sharpee/core';",
      "",
      "export const ${1:DAEMON_ID} = '${2:story.daemon.name}';",
      "",
      "function create${3:MyDaemon}(): Daemon {",
      "\treturn {",
      "\t\tid: ${1:DAEMON_ID},",
      "\t\tname: '${4:Daemon Name}',",
      "\t\tpriority: ${5:1},",
      "",
      "\t\tcondition: (ctx: SchedulerContext): boolean => {",
      "\t\t\t${6:return true;}",
      "\t\t},",
      "",
      "\t\trun: (ctx: SchedulerContext): ISemanticEvent[] => {",
      "\t\t\t${7:return [];}",
      "\t\t}",
      "\t};",
      "}",
      "",
      "export function register${3:MyDaemon}(scheduler: ISchedulerService): void {",
      "\tscheduler.registerDaemon(create${3:MyDaemon}());",
      "}"
    ],
    "description": "Create a daemon (recurring timed event) with condition and run phases"
  },

  "Sharpee: Fuse": {
    "prefix": "fuse",
    "body": [
      "import { Fuse, SchedulerContext, ISchedulerService } from '@sharpee/plugin-scheduler';",
      "import { ISemanticEvent } from '@sharpee/core';",
      "",
      "export const ${1:FUSE_ID} = '${2:story.fuse.name}';",
      "",
      "function create${3:MyFuse}(entityId: string): Fuse {",
      "\treturn {",
      "\t\tid: ${1:FUSE_ID},",
      "\t\tname: '${4:Fuse Name}',",
      "\t\tturns: ${5:10},",
      "\t\tentityId,",
      "\t\tpriority: ${6:10},",
      "",
      "\t\ttickCondition: (ctx: SchedulerContext): boolean => {",
      "\t\t\t${7:return true;}",
      "\t\t},",
      "",
      "\t\ttrigger: (ctx: SchedulerContext): ISemanticEvent[] => {",
      "\t\t\t${8:// Fuse triggered — perform mutations and return events}",
      "\t\t\treturn [];",
      "\t\t}",
      "\t};",
      "}",
      "",
      "export function register${3:MyFuse}(scheduler: ISchedulerService, entityId: string): void {",
      "\tscheduler.setFuse(create${3:MyFuse}(entityId));",
      "}"
    ],
    "description": "Create a fuse (one-shot timed event) with tick condition and trigger"
  },

  "Sharpee: Trait": {
    "prefix": "trait",
    "body": [
      "import { ITrait } from '@sharpee/world-model';",
      "",
      "export interface ${1:MyTrait}Config {",
      "\t${2:property}: ${3:string};",
      "}",
      "",
      "export class ${1:MyTrait} implements ITrait {",
      "\tstatic readonly type = '${4:story.trait.name}' as const;",
      "\tstatic readonly capabilities = [${5:'if.action.name'}] as const;",
      "",
      "\treadonly type = ${1:MyTrait}.type;",
      "",
      "\t${2:property}: ${3:string};",
      "",
      "\tconstructor(config: ${1:MyTrait}Config) {",
      "\t\tthis.${2:property} = config.${2:property};",
      "\t}",
      "}"
    ],
    "description": "Create a custom trait with static type, capabilities, and config"
  },

  "Sharpee: Behavior": {
    "prefix": "behavior",
    "body": [
      "import {",
      "\tCapabilityBehavior,",
      "\tCapabilityValidationResult,",
      "\tCapabilityEffect,",
      "\tCapabilitySharedData,",
      "\tcreateEffect,",
      "\tIFEntity,",
      "\tWorldModel",
      "} from '@sharpee/world-model';",
      "",
      "export const ${1:myBehavior}: CapabilityBehavior = {",
      "\tvalidate(",
      "\t\tentity: IFEntity,",
      "\t\tworld: WorldModel,",
      "\t\tactorId: string,",
      "\t\tsharedData: CapabilitySharedData",
      "\t): CapabilityValidationResult {",
      "\t\t${2:// Validate preconditions}",
      "\t\treturn { valid: true };",
      "\t},",
      "",
      "\texecute(",
      "\t\tentity: IFEntity,",
      "\t\tworld: WorldModel,",
      "\t\tactorId: string,",
      "\t\tsharedData: CapabilitySharedData",
      "\t): void {",
      "\t\t${3:// Perform state mutations}",
      "\t},",
      "",
      "\treport(",
      "\t\tentity: IFEntity,",
      "\t\tworld: WorldModel,",
      "\t\tactorId: string,",
      "\t\tsharedData: CapabilitySharedData",
      "\t): CapabilityEffect[] {",
      "\t\treturn [createEffect('${4:event.type}', {",
      "\t\t\tmessageId: '${5:message.id}',",
      "\t\t\ttargetId: entity.id",
      "\t\t})];",
      "\t},",
      "",
      "\tblocked(",
      "\t\tentity: IFEntity,",
      "\t\tworld: WorldModel,",
      "\t\tactorId: string,",
      "\t\terror: string,",
      "\t\tsharedData: CapabilitySharedData",
      "\t): CapabilityEffect[] {",
      "\t\treturn [createEffect('${6:event.blocked}', {",
      "\t\t\tmessageId: error,",
      "\t\t\tparams: { target: entity.name }",
      "\t\t})];",
      "\t}",
      "};"
    ],
    "description": "Create a CapabilityBehavior with four-phase pattern (validate/execute/report/blocked)"
  }
}
