# Zifmia operator-tunable knobs.
# Copy to `.env` next to docker-compose.yml and edit; docker compose
# auto-loads it.

# Host port to publish (container always listens on 3000 internally).
ZIFMIA_PORT=3000

# Recording-notice banner shown to all participants in every room.
# Leave unset to use the built-in default.
# ZIFMIA_RECORDING_NOTICE="All commands are recorded for moderation."

# PH-disconnect grace window in milliseconds before succession fires.
# Default 30000 (30 seconds). Lower for testing; do not raise above a
# few minutes — long graces hold rooms in limbo.
# ZIFMIA_GRACE_MS=30000
