# Zifmia environment configuration. Copy to `.env` before `docker compose up`.
#
# All variables are optional — defaults below match the SQLite single-
# container baseline.

# HTTP listener.
ZIFMIA_PORT=3000
ZIFMIA_HOST=0.0.0.0

# Storage selection. Leave ZIFMIA_DB_URL unset to use SQLite (default).
# ZIFMIA_DB_URL=postgres://zifmia:password@localhost:5432/zifmia
ZIFMIA_SQLITE_PATH=/data/zifmia.db
