# Sharpee Multiuser Server — environment variable template.
# Copy to `.env` and edit. All values also expressible in sharpee-platform.yaml;
# env vars take precedence.

# Listening port for HTTP + WebSocket (single port).
PORT=8080

# Path to SQLite database file. Created if missing.
DB_PATH=./data/sharpee.db

# Directory of preloaded .sharpee story files the server may launch.
# The server does NOT accept story uploads; operators place files here.
STORIES_DIR=./data/stories

# Path to operator YAML config file (optional; env vars override).
CONFIG_FILE=./sharpee-platform.yaml

# CAPTCHA provider configuration. Provider is one of:
#   turnstile | hcaptcha | friendly | none
# Setting provider to `none` disables the check — INTENDED FOR DEV ONLY.
CAPTCHA_PROVIDER=none
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Set to 1 to bypass CAPTCHA validation in tests/CI. NEVER set in production.
CAPTCHA_BYPASS=0

# Idle room recycle window (days). Rooms with no activity for this long
# are cascade-deleted by the recycle sweeper.
ROOMS_IDLE_RECYCLE_DAYS=14
