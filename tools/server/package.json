{
  "name": "sharpee-server",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Multiuser Sharpee server — rooms, presence, lock-on-typing, Deno-sandboxed story execution (ADR-153).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
