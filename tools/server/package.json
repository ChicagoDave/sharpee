    "ws": "^8.18.0",
    "yaml": "^2.6.0",
    "@sharpee/core": "file:../../packages/core"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
