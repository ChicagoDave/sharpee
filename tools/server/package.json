{
  "name": "sharpee-server",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Multiuser Sharpee server — rooms, presence, lock-on-typing, Deno-sandboxed story execution (ADR-153).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/identity/eff-large-wordlist.txt dist/identity/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@sharpee/core": "workspace:*",
    "@sharpee/engine": "workspace:*",
    "@sharpee/event-processor": "workspace:*",
    "@sharpee/if-domain": "workspace:*",
    "@sharpee/lang-en-us": "workspace:*",
    "@sharpee/media": "workspace:*",
    "@sharpee/parser-en-us": "workspace:*",
    "@sharpee/platform-browser": "workspace:*",
    "@sharpee/plugin-npc": "workspace:*",
    "@sharpee/plugin-scheduler": "workspace:*",
    "@sharpee/plugin-state-machine": "workspace:*",
    "@sharpee/queries": "workspace:*",
    "@sharpee/stdlib": "workspace:*",
    "@sharpee/text-service": "workspace:*",
    "@sharpee/world-model": "workspace:*",
    "argon2": "^0.44.0",
    "better-sqlite3": "^11.3.0",
    "esbuild": "^0.27.2",
    "fflate": "^0.8.2",
    "hono": "^4.6.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
