# V12 teaches: world.chainEvent() for reacting to stdlib actions

# Go to the Petting Zoo and pick up the feed
> south
[OK: contains "Main Path"]

> east
[OK: contains "Petting Zoo"]

> take feed
[OK: contains "Taken"]

# Drop the feed — the goats should react
> drop feed
[OK: contains "goats"]
[OK: contains "bleating"]

