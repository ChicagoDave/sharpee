{
  "name": "familyzoo",
  "version": "1.0.0",
  "description": "Family Zoo — the standalone tutorial for The Sharpee Author and Developer Manual",
  "type": "module",
  "main": "dist/index.js",
  "sharpee": {
    "themes": [
      "modern-dark",
      "retro-terminal",
      "paper",
      "system-6",
      { "id": "zoo-sunny", "name": "Zoo Sunny" }
    ]
  },
  "scripts": {
    "build": "sharpee build",
    "build:browser": "sharpee build-browser",
    "clean": "sharpee clean"
