title: Debug Combat
story: dungeo
---
# GDT ND = immortality: the troll's counterblows can kill a score-0 player
# outright; ND only suppresses the hero-death event, so the attack loop and
# troll death below are unaffected.
> gdt
[OK: contains "GDT"]

> nd
[OK: contains "Immortality"]

> ex
[OK: contains "Returning"]

> north
[OK: contains "North"]
> east
[OK: contains "Behind"]
> open window
[OK: contains "open"]
> west
[OK: contains "Kitchen"]
> west
[OK: contains "Living Room"]
> take sword
[OK: contains "Taken"]
> take lantern
[OK: contains "Taken"]
> switch on lantern
[OK: contains "on"]
> push rug
[OK: contains "trap door"]
> open trapdoor
[OK: contains "open"]
> down
[OK: contains "Cellar"]
> east
[OK: contains "Troll Room"]

# Test with RETRY (triggers save/restore) + DO/UNTIL
# RNG: the troll's swing can disarm us (sword drops) - recover it first,
# and the disarm line ("knocks your sword out of your hand") mentions
# neither "troll" nor "staggering", so "sword" is a valid outcome too.
[RETRY: max=5]
[DO]
[WHILE: not inventory contains "elvish sword"]
> take sword
[SKIP]
[END WHILE]
> attack troll with sword
[OK: contains_any "troll" "staggering" "sword"]
[UNTIL "slumps to the floor dead" OR "removes his head" OR "He dies" OR "You are dead"]
[ENSURES: not entity "troll" alive]
[END RETRY]
