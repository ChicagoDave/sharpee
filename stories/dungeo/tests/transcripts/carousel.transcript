title: Low Room Carousel (Magnet Room)
story: dungeo
description: Tests the Low Room carousel exit randomization and button toggle (MDL act3 MAGNET-ROOM-EXIT)

---

# MDL act3.mud: CAROUSEL-FLIP!-FLAG starts FALSE.
# Flag false  -> Low Room exits deterministic (E -> Machine Room, SE -> Tea Room),
#                no compass message on entry.
# Flag true (after button push) -> compass spins on entry, all exits randomly
#                go to Machine Room or Tea Room ("You cannot get your bearings...").

# Setup - get light source
> gdt
[OK: contains "GDT ready"]

> tk brass lantern
[OK: contains "Taken"]

# Teleport to Tea Room (adjacent to Low Room via NW)
> ah Tea Room
[OK: contains "Teleported"]

> ex
[OK: contains "Returning to game"]

> turn on lantern
[OK: contains "on"]

# ============================================================
# Part 1: Flag false - deterministic exits, no compass spinning
# ============================================================

# Go northwest from Tea Room to Low Room - no compass message yet
> northwest
[OK: contains "Low Room"]
[OK: not contains "compass"]

# Go east - deterministic: always Machine Room
> east
[OK: contains "Machine Room"]
[OK: not contains "cannot get your bearings"]

# ============================================================
# Part 2: Toggle carousel via robot button push
# ============================================================

# Teleport to well-area Machine Room (use alias to avoid coal mine one)
> gdt
[OK: contains "GDT ready"]

> ah button machine room
[OK: contains "Teleported"]

# Move robot to current location
> ao robot here
[OK: contains "Moved"]

> ex
[OK: contains "Returning to game"]

# Verify robot is present
> look
[OK: contains "Machine Room"]
[OK: contains "robot"]

# Tell robot to push the triangular button
> tell robot to push button
[OK: contains "pushes"]
[OK: contains "carousel"]

# ============================================================
# Part 3: Flag true - compass spins, exits randomized
# ============================================================

# Go west to Low Room - compass spinning message on entry
> west
[OK: contains "Low Room"]
[OK: contains "compass starts spinning"]

# Any exit now randomly goes to Machine Room or Tea Room (PROB 50)
> east
[OK: contains "cannot get your bearings"]
[OK: contains_any "Machine Room" "Tea Room"]

# Bounce through the Low Room until we land in the Tea Room
[WHILE: not location = "Tea Room"]
> southeast
[SKIP]
[IF: not location = "Tea Room"]
[NAVIGATE TO: "Low Room"]
[END IF]
[END WHILE]

# Confirm we escaped to the Tea Room
> look
[OK: contains "Tea Room"]
