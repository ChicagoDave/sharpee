title: Save/Restore Basic Test
story: dungeo
description: Tests basic $save and $restore functionality

---

# Start in West of House, verify initial state
> look
[OK: contains "West of House"]

# Save initial state
$save test-checkpoint-1

# Go inside and take something
> open mailbox
[OK: contains "leaflet"]

> take leaflet
[OK: contains "Taken"]

> inventory
[OK: contains "leaflet"]

# Restore should put us back - player inventory empty
$restore test-checkpoint-1

# After restore, inventory should be empty again
# (empty-inventory phrasing varies: "Your pockets are empty." /
#  "You aren't carrying anything at all.")
> inventory
[OK: contains_any "empty" "aren't carrying"]

# The mailbox should be closed again (restore resets state)
# Note: The mailbox still contains the leaflet
> open mailbox
[OK: contains "open"]

# Verify the leaflet is back in the mailbox by checking events
# (The reveal message may not show again due to session state)
> examine mailbox
[OK: contains "mailbox"]
