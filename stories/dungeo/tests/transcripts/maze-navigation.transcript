title: Maze Navigation
story: dungeo
description: Test maze room connections per 1981 MDL source

---

# Death is possible en route (hungry cyclops on entry, the troll while passing
# through the Troll Room, the thief roaming the maze). RETRY restores the
# turn-0 snapshot and revives the engine on death (same pattern as debug-combat).
[RETRY: max=5]

# Setup: Get lantern and teleport to Grating Room
> gdt
[OK: contains "GAME DEBUGGING TOOL"]

> tk brass lantern
[OK: contains "Taken: brass lantern"]

> nd
[OK: contains "Immortality"]

> ah grating room
[OK: contains "Teleported to"]
[OK: contains "Grating Room"]

> ex
[OK: contains "Returning to game"]

# Turn on lantern (maze is dark)
> turn on lantern
[OK: contains "lantern"]
[EVENT: true, type="if.event.switched_on"]

# Verify we're in Grating Room
> look
[OK: contains "Grating Room"]
[OK: contains "small room near the surface"]

# ============================================================================
# TEST: Grating Room to Cyclops Room path
# Path: GR SWâ†’MAZ11 SWâ†’MAZ12 Wâ†’MAZE5 SWâ†’MAZE6 Eâ†’MAZE7 Sâ†’MAZ15 NEâ†’CYCLO
# ============================================================================

# Enter the maze - southwest leads to Maze-11 (not Maze-12!)
> southwest
[OK: contains "maze"]
[OK: contains "twisty little passages"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-11: southwest to Maze-12
> southwest
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-12: west to Maze-5 (where items are)
> west
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# Verify we're in Maze-5 (should see skeleton, bag of coins, etc.)
> look
[OK: contains "maze"]

# From Maze-5: southwest to Maze-6
> southwest
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-6: east to Maze-7
> east
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-7: south to Maze-15
> south
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-15: northeast to Cyclops Room
> northeast
[OK: contains "Cyclops"]
[EVENT: true, type="if.event.actor_moved"]

# From Cyclops Room: up to Treasure Room
> up
[OK: contains "Treasure Room"]
[EVENT: true, type="if.event.actor_moved"]

# Navigate back down to Cyclops Room
> down
[OK: contains "Cyclops"]
[EVENT: true, type="if.event.actor_moved"]

# ============================================================================
# TEST: Troll Room to Maze entry and navigation
# Path: Troll Sâ†’MAZE1 Eâ†’MAZE4 Wâ†’MAZE3 UPâ†’MAZE5
# ============================================================================

> gdt
[OK: contains "GAME DEBUGGING TOOL"]

> ah troll room
[OK: contains "Teleported to"]

> ex
[OK: contains "Returning to game"]

# South from Troll Room leads to Maze-1
> south
[OK: contains "maze"]
[OK: contains "twisty little passages"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-1: east to Maze-4
> east
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-4: west to Maze-3
> west
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-3: up to Maze-5
> up
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-5: north to Maze-3 (back)
> north
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# ============================================================================
# TEST: Deeper maze navigation (Maze-9 to Maze-11 area)
# Path: MAZE9 Eâ†’MAZ11 NEâ†’GRAT (Grating Room)
# ============================================================================

> gdt
[OK: contains "GAME DEBUGGING TOOL"]

> ah maze 9
[OK: contains "Teleported to"]

> ex
[OK: contains "Returning to game"]

# From Maze-9: east to Maze-11
> east
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-11: northeast to Grating Room
> northeast
[OK: contains "Grating Room"]
[EVENT: true, type="if.event.actor_moved"]

# ============================================================================
# TEST: Maze-14/15 connections (near Cyclops exit)
# Path: MAZ14 Wâ†’MAZ15 NEâ†’CYCLO
# ============================================================================

> gdt
[OK: contains "GAME DEBUGGING TOOL"]

> ah maze 14
[OK: contains "Teleported to"]

> ex
[OK: contains "Returning to game"]

# From Maze-14: west to Maze-15
> west
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

# From Maze-15: northeast to Cyclops Room
> northeast
[OK: contains "Cyclops"]
[EVENT: true, type="if.event.actor_moved"]

# Back to maze: west to Maze-15
> west
[OK: contains "maze"]
[EVENT: true, type="if.event.actor_moved"]

[END RETRY]
