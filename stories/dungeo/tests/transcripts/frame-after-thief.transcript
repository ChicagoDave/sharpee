title: Canvas Puzzle - Frame Mechanics
story: dungeo
description: Test ADR-078 frame spawning, scenery, reading, and breaking after thief death
---

# Kill the thief via GDT — spawns the empty frame in the Treasure Room
# (wt-13 now breaks the frame itself, so this test creates its own state)
> gdt
[OK: contains "GDT"]

> tk brass lantern
[OK: contains "Taken"]

> kl thief
[OK: contains "Killed"]

> ah Treasure Room
[OK: contains "Teleported"]

> ex
[OK: contains "Returning"]

> turn on lantern
[OK: contains "on"]

# Frame should be visible in room
> look
[OK: contains "empty frame"]

# Examine should show description with writing hint
> examine frame
[OK: contains "carved"]
[OK: contains "back"]

# Read while on wall should fail with custom message
> read frame
[OK: contains "difficult"]

# Try take — should be blocked (scenery)
> take frame
[OK: contains "mounted on the wall"]

# Break frame should work and reveal the carved piece
> break frame
[OK: contains "shatters"]
[OK: contains "devotion"]

# Frame piece should be on floor
> look
[OK: contains "frame piece"]

# Take and read the piece
> take frame piece
[OK: contains "Taken"]

> read frame piece
[OK: contains "devotion"]
