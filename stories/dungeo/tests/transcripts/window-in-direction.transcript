# Test ISSUE-002: "in" should enter through window at Behind House
# Verifies "in" works as an alias for going through the open window

# Go to Behind House
> n
[OK: contains "North of House"]

> e
[OK: contains "Behind House"]

# Try "in" with closed window - should fail
> in
[OK: contains "closed"]

# Open the window
> open window
[OK: contains "open"]

# Now "in" should work to enter the Kitchen
> in
[OK: contains "Kitchen"]
