{
  "name": "@sharpee/devkit",
  "version": "3.0.0",
  "description": "The Sharpee CLI engine — build/test/verify/scaffold orchestration (ADR-180). Provides the `sharpee` command; orchestrates, tsf compiles.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sharpee": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@sharpee/bootstrap": "workspace:*",
    "@sharpee/chord": "workspace:*",
    "@sharpee/core": "workspace:*",
    "@sharpee/engine": "workspace:*",
    "@sharpee/story-loader": "workspace:*",
    "@sharpee/transcript-tester": "workspace:*",
    "@sharpee/world-model": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "fixtures",
    "templates"
  ],
  "keywords": [
    "interactive-fiction",
    "if",
    "sharpee",
    "devkit",
    "build-tool"
  ],
  "author": "Sharpee Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChicagoDave/sharpee.git",
    "directory": "packages/devkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
