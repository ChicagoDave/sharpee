{
  "name": "@sharpee/story-runtime-baseline",
  "version": "1.1.1",
  "description": "Story Runtime Baseline manifest (ADR-178). Declares the canonical set of packages a .sharpee story bundle may import. Used by Zifmia to install the baseline transitively and by the story build to validate bundles against the contract.",
  "main": "./dist/index.js",
  "module": "./dist-esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist-esm/index.js",
      "require": "./dist/index.js",
      "esm": "./dist-esm/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "clean": "rimraf dist dist-esm tsconfig.tsbuildinfo tsconfig.esm.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@sharpee/core": "workspace:*",
    "@sharpee/engine": "workspace:*",
    "@sharpee/event-processor": "workspace:*",
    "@sharpee/if-domain": "workspace:*",
    "@sharpee/if-services": "workspace:*",
    "@sharpee/lang-en-us": "workspace:*",
    "@sharpee/media": "workspace:*",
    "@sharpee/parser-en-us": "workspace:*",
    "@sharpee/platform-browser": "workspace:*",
    "@sharpee/plugin-npc": "workspace:*",
    "@sharpee/plugin-scheduler": "workspace:*",
    "@sharpee/plugin-state-machine": "workspace:*",
    "@sharpee/queries": "workspace:*",
    "@sharpee/stdlib": "workspace:*",
    "@sharpee/text-blocks": "workspace:*",
    "@sharpee/world-model": "workspace:*",
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "dist-esm"
  ],
  "keywords": [
    "sharpee",
    "interactive-fiction",
    "manifest",
    "baseline"
  ],
  "author": "Sharpee Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChicagoDave/sharpee.git",
    "directory": "packages/story-runtime-baseline"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
