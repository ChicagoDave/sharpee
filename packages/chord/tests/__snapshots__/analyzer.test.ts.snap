          "span": {
            "column": 3,
            "endColumn": 56,
            "endLine": 32,
            "line": 30,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "The bar, much rougher than you'd have guessed after the opulence of the foyer to the north, is completely empty. There seems to be some sort of message scrawled in the sawdust on the floor.",
            },
          ],
        },
        "foyer-of-the-opera-house.description": {
          "span": {
            "column": 3,
            "endColumn": 65,
            "endLine": 17,
            "line": 15,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You are standing in a spacious hall, splendidly decorated in red and gold, with glittering chandeliers overhead. The entrance from the street is to the north, and there are doorways south and west.",
