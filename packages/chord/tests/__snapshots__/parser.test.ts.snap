            "span": {
              "column": 5,
              "endColumn": 25,
              "endLine": 87,
              "line": 86,
            },
            "text": "You've only just arrived, and besides, the weather outside seems to be getting worse.",
          },
        },
        {
          "key": "stumble",
          "span": {
            "column": 3,
            "endColumn": 53,
            "endLine": 89,
            "line": 88,
          },
          "value": {
            "form": "prose",
            "kind": "text",
            "markers": [],
            "span": {
              "column": 5,
              "endColumn": 53,
              "endLine": 89,
              "line": 89,
            },
            "text": "Blundering around in the dark isn't a good idea!",
          },
        },
        {
          "key": "message-intact",
          "span": {
            "column": 3,
            "endColumn": 70,
            "endLine": 91,
            "line": 90,
          },
          "value": {
            "form": "prose",
            "kind": "text",
            "markers": [],
            "span": {
              "column": 5,
              "endColumn": 70,
              "endLine": 91,
              "line": 91,
            },
            "text": "The message, neatly marked in the sawdust, reads... You have won!",
          },
        },
        {
          "key": "message-trampled",
          "span": {
            "column": 3,
            "endColumn": 37,
            "endLine": 93,
            "line": 92,
          },
          "value": {
            "form": "prose",
            "kind": "text",
            "markers": [
              {
                "content": "garbled",
                "span": {
                  "column": 28,
                  "endColumn": 37,
                  "endLine": 93,
                  "line": 93,
                },
              },
            ],
            "span": {
              "column": 5,
              "endColumn": 37,
              "endLine": 93,
              "line": 93,
            },
            "text": "You can just make out: {garbled}",
          },
        },
        {
          "key": "message-obliterated",
          "span": {
            "column": 3,
            "endColumn": 69,
            "endLine": 95,
            "line": 94,
          },
          "value": {
            "form": "prose",
            "kind": "text",
            "markers": [],
            "span": {
              "column": 5,
              "endColumn": 69,
              "endLine": 95,
              "line": 95,
            },
            "text": "The message has been trampled beyond recognition. You have lost!",
          },
        },
      ],
