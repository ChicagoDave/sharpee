    "fields": {
      "blurb": "PHASE C SKETCH (givens 8+9 ownership package) — review artifact, does not compile under Phase B grammar.",
      "id": "friendly-zoo",
      "version": "0.0.2-phase-c-sketch",
    },
    "title": "Friendly Zoo",
  },
  "phrasebooks": [],
  "phrases": {
    "defaultLocale": "en-US",
    "locales": {
      "en-US": {
        "already-fed": {
          "span": {
            "column": 5,
            "endColumn": 59,
            "endLine": 452,
            "line": 451,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You've already fed them. They look contentedly full.",
            },
          ],
        },
        "aviary-plaque.description": {
          "span": {
            "column": 3,
            "endColumn": 57,
            "endLine": 305,
            "line": 305,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A colorful information board near the aviary entrance.",
            },
          ],
        },
        "aviary-plaque.plaque-text": {
          "span": {
            "column": 7,
            "endColumn": 74,
            "endLine": 313,
            "line": 309,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "WELCOME TO THE AVIARY — Home to over 30 species!

TOCO TOUCAN — Its bill weighs less than a smartphone.

SCARLET MACAW — Can live over 75 years. Our oldest, Captain, is 42.",
            },
          ],
        },
        "aviary.description": {
          "span": {
            "column": 3,
            "endColumn": 8,
            "endLine": 53,
            "line": 49,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You step inside a soaring mesh dome. Brilliantly colored parrots chatter from rope perches, and a toucan eyes you curiously from a branch overhead. A small waterfall splashes into a stone basin. An info plaque hangs near the entrance. The gift shop is to the west. The main path is back to the east.",
            },
          ],
        },
        "aviary.parrot-nods": {
          "span": {
            "column": 7,
            "endColumn": 27,
            "endLine": 67,
            "line": 66,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "The parrot glances at you and nods, as if recognizing a fellow after-hours regular.",
            },
          ],
        },
        "aviary.parrot-notices": {
          "span": {
            "column": 7,
            "endColumn": 66,
            "endLine": 61,
            "line": 61,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
