          ],
        },
        "info-plaque.plaque-text": {
          "span": {
            "column": 7,
            "endColumn": 41,
            "endLine": 297,
            "line": 293,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "PYGMY GOATS — These Nigerian Dwarf goats are gentle, curious, and always hungry.

HOLLAND LOP RABBITS — Known for their floppy ears. Our pair, Biscuit and Marmalade, were born here in 2023.",
            },
          ],
        },
        "iron-fence.description": {
          "span": {
