        },
        "staff-keycard.description": {
          "span": {
            "column": 3,
            "endColumn": 8,
            "endLine": 129,
            "line": 128,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A white plastic keycard with "WILLOWBROOK ZOO — STAFF ONLY" printed in blue.",
            },
          ],
        },
        "staff-parking-lot.description": {
          "span": {
            "column": 3,
            "endColumn": 74,
            "endLine": 117,
            "line": 117,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A small staff parking lot beyond the zoo fence. Off limits to visitors.",
            },
          ],
        },
        "stuffed-animals.description": {
          "span": {
            "column": 3,
            "endColumn": 49,
            "endLine": 260,
            "line": 260,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Shelves of plush tigers, pandas, and penguins.",
            },
          ],
        },
        "sugar-gliders.description": {
          "span": {
            "column": 3,
            "endColumn": 58,
            "endLine": 220,
            "line": 220,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A family of tiny sugar gliders with enormous dark eyes.",
            },
          ],
        },
        "supply-room.description": {
          "span": {
            "column": 3,
            "endColumn": 9,
            "endLine": 81,
            "line": 78,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A cluttered storage room behind the staff gate. Metal shelves line the walls. A cork board on the wall is covered with staff schedules. A battered radio sits on one of the shelves. The staff gate leads back north.",
            },
          ],
        },
        "ticket-booth.description": {
          "span": {
            "column": 3,
            "endColumn": 56,
            "endLine": 157,
            "line": 157,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A small wooden booth with a "Self-Guided Tours" sign.",
            },
          ],
        },
        "took-photo": {
          "span": {
            "column": 5,
            "endColumn": 14,
            "endLine": 527,
            "line": 525,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [
                "the target",
              ],
              "text": "Click! You snap a photo of {the target}. That one's going on the fridge.",
            },
          ],
        },
        "toucan.description": {
          "span": {
            "column": 3,
            "endColumn": 56,
            "endLine": 192,
            "line": 192,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A Toco toucan with an enormous orange-and-black bill.",
            },
          ],
        },
        "victory": {
          "span": {
            "column": 3,
            "endColumn": 25,
            "endLine": 751,
            "line": 745,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Congratulations! You've earned your MASTER ZOOKEEPER badge! You've visited every exhibit, befriended the animals, collected souvenirs, and even stayed after hours to hear what the animals really think. The Willowbrook Family Zoo will never forget you!

*** You have won ***",
            },
          ],
        },
        "warning-sign.description": {
          "span": {
            "column": 3,
            "endColumn": 61,
            "endLine": 322,
            "line": 322,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A yellow warning sign near the nocturnal exhibit entrance.",
            },
          ],
        },
        "warning-sign.sign-text": {
          "span": {
            "column": 7,
            "endColumn": 25,
            "endLine": 328,
            "line": 326,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "CAUTION: The Nocturnal Animals Exhibit is kept dark. Please use a flashlight. Do NOT use camera flash. (We don't talk about the Great Owl Incident of 2022.)",
            },
          ],
        },
        "waterfall.description": {
          "span": {
            "column": 3,
            "endColumn": 62,
            "endLine": 199,
            "line": 199,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A gentle artificial waterfall cascading into a stone basin.",
            },
          ],
        },
        "welcome-sign.description": {
          "span": {
            "column": 3,
            "endColumn": 77,
            "endLine": 150,
            "line": 150,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A brightly painted wooden sign reads: "WELCOME TO WILLOWBROOK FAMILY ZOO."",
            },
          ],
        },
        "zoo-brochure.description": {
          "span": {
            "column": 3,
            "endColumn": 73,
            "endLine": 337,
            "line": 337,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A glossy tri-fold brochure with "WILLOWBROOK FAMILY ZOO" on the cover.",
            },
          ],
        },
        "zoo-entrance.description": {
          "span": {
            "column": 3,
            "endColumn": 50,
            "endLine": 16,
            "line": 13,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You stand before the wrought-iron gates of the Willowbrook Family Zoo. A cheerful welcome sign arches over the entrance, and a small ticket booth sits to one side. A sturdy iron fence runs along either side of the gates. The main path leads south into the zoo grounds.",
            },
          ],
        },
        "zoo-feeding-time-announced": {
          "span": {
            "column": 7,
            "endColumn": 54,
            "endLine": 689,
            "line": 688,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "*DING DONG* "It's FEEDING TIME at the Petting Zoo! Come watch our pygmy goats and rabbits enjoy their favorite snacks!"",
            },
          ],
        },
        "zoo-map.description": {
          "span": {
            "column": 3,
            "endColumn": 56,
            "endLine": 349,
            "line": 349,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A colorful folding map of the Willowbrook Family Zoo.",
            },
          ],
        },
        "zoo-pa-closed": {
          "span": {
            "column": 7,
            "endColumn": 48,
            "endLine": 680,
            "line": 679,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "*DING DONG* "The Willowbrook Family Zoo is now closed. Thank you for visiting! We hope to see you again soon!"",
            },
          ],
        },
        "zoo-pa-closing-1": {
          "span": {
            "column": 7,
            "endColumn": 40,
            "endLine": 676,
            "line": 675,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "*DING DONG* "Attention visitors! One hour until closing. Please begin making your way toward the exit."",
            },
          ],
        },
        "zoo-pa-closing-2": {
          "span": {
            "column": 7,
            "endColumn": 47,
            "endLine": 672,
            "line": 671,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "*DING DONG* "Attention visitors! Two hours until closing. Don't forget to stop by the gift shop for souvenirs!"",
            },
          ],
        },
        "zoo-pa-closing-3": {
          "span": {
            "column": 7,
            "endColumn": 21,
            "endLine": 668,
            "line": 666,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "*DING DONG* "Attention visitors! The Willowbrook Family Zoo will be closing in three hours. Please make sure to visit all exhibits before closing time!"",
            },
          ],
        },
        "zookeeper.departs": {
          "span": {
            "column": 7,
            "endColumn": 16,
            "endLine": 547,
            "line": 543,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "The zookeeper glances at the clock, unclips the walkie-talkie from his belt, and stretches. "Well, that's me done for the day. Zoo's all yours, I guess!" He gives you a friendly wave and ambles off toward the staff parking lot. A moment later, you hear an engine start and fade into the distance.",
            },
          ],
        },
        "zookeeper.description": {
          "span": {
            "column": 3,
            "endColumn": 66,
            "endLine": 535,
            "line": 535,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A friendly zookeeper in khaki overalls. A name tag reads "Sam."",
            },
          ],
        },
        "zookeeper.presence": {
          "span": {
            "column": 3,
            "endColumn": 56,
            "endLine": 538,
            "line": 537,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Sam the zookeeper is here, jingling a ring of keys.",
            },
          ],
        },
      },
    },
  },
