        "info-plaque.description": {
          "span": {
            "column": 3,
            "endColumn": 69,
            "endLine": 289,
            "line": 289,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A brass plaque mounted on a wooden post near the petting zoo gate.",
