          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A small juice box with a picture of a happy elephant.",
            },
          ],
        },
        "lunchbox.description": {
          "span": {
            "column": 3,
            "endColumn": 62,
            "endLine": 386,
            "line": 386,
          },
          "strategy": null,
          "variants": [
            {
