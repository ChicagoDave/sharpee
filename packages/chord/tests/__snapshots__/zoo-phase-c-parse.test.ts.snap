        "gift-shop.description": {
          "span": {
            "column": 3,
            "endColumn": 55,
            "endLine": 107,
            "line": 105,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A small zoo gift shop crammed with stuffed animals and postcards. A large souvenir penny press machine stands near the door. A disposable camera sits on the counter. The aviary is back to the east.",
            },
          ],
