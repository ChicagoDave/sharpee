        "main-path.description": {
          "span": {
            "column": 3,
            "endColumn": 56,
            "endLine": 28,
            "line": 25,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A wide gravel path winds through the heart of the zoo. Colorful direction signs point every which way. A park bench sits beside the path. To the east, the petting zoo. To the west, the aviary. A staff gate blocks the path to the south. The entrance is back to the north.",
            },
          ],
        },
        "metal-shelves.description": {
          "span": {
            "column": 3,
            "endColumn": 57,
            "endLine": 212,
            "line": 212,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Industrial metal shelving units stacked with supplies.",
            },
          ],
        },
        "no-camera": {
          "span": {
            "column": 5,
            "endColumn": 61,
            "endLine": 523,
            "line": 522,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You don't have a camera. There's one in the gift shop.",
            },
          ],
        },
        "no-feed": {
          "span": {
            "column": 5,
            "endColumn": 38,
            "endLine": 450,
            "line": 449,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You don't have any animal feed.",
            },
          ],
        },
        "nocturnal-animals-exhibit.description": {
          "span": {
            "column": 3,
            "endColumn": 44,
            "endLine": 94,
            "line": 91,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A cool, dimly lit cavern designed to simulate nighttime. Glass enclosures line both walls with soft red lights. You can see sugar gliders, bush babies, and a barn owl. A warning sign is posted near the entrance. The exit leads back north to the supply room.",
            },
          ],
        },
        "not-an-animal": {
          "span": {
            "column": 5,
            "endColumn": 41,
            "endLine": 509,
            "line": 508,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "That's not something you can feed.",
            },
          ],
        },
        "park-bench.description": {
          "span": {
            "column": 3,
            "endColumn": 44,
            "endLine": 378,
            "line": 378,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A sturdy park bench painted forest green.",
            },
          ],
        },
        "parrot-candor": {
          "span": {
            "column": 1,
            "endColumn": 11,
            "endLine": 727,
            "line": 712,
          },
          "strategy": "randomly",
          "variants": [
            {
              "markers": [],
              "text": "Finally, they're gone. Do you know how exhausting it is to say "Polly wants a cracker" eight hours a day?",
            },
            {
              "markers": [],
              "text": "Between you and me, the toucan is a complete diva. Won't shut up about its bill.",
            },
            {
              "markers": [],
              "text": "I have a degree in ornithology, you know. Well, I would, if birds could enroll.",
            },
            {
              "markers": [],
              "text": "The gift shop markup is criminal. Three dollars for a postcard? In this economy?",
            },
            {
              "markers": [],
              "text": "You seem alright. Most visitors just want selfies. At least you're still here.",
            },
          ],
        },
        "parrot-chatter": {
          "span": {
            "column": 1,
            "endColumn": 11,
            "endLine": 710,
            "line": 700,
          },
          "strategy": "randomly",
          "variants": [
            {
              "markers": [],
              "text": "Polly wants a cracker!",
            },
            {
              "markers": [],
              "text": "SQUAWK! Pretty bird! Pretty bird!",
            },
            {
              "markers": [],
              "text": "Pieces of eight! Pieces of eight!",
            },
            {
              "markers": [],
              "text": "Who's a good bird? WHO'S A GOOD BIRD?",
            },
            {
              "markers": [],
              "text": "BAWK! Welcome to the zoo!",
            },
          ],
        },
        "parrot.confession": {
          "span": {
            "column": 7,
            "endColumn": 25,
            "endLine": 583,
            "line": 579,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "The parrot clears its throat — actually clears its throat — and fixes you with a knowing look. "Right then. Now that the performative squawking is over, let me tell you something: that toucan? Complete fraud. Can't even crack a nut properly. And don't get me started on the gift shop markup."",
            },
          ],
        },
        "parrot.description": {
          "span": {
            "column": 3,
            "endColumn": 35,
            "endLine": 560,
            "line": 559,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A magnificent scarlet macaw perched on a rope. It tilts its head and watches you with one bright eye.",
            },
          ],
        },
        "parrot.parrot-look": {
          "span": {
            "column": 7,
            "endColumn": 22,
            "endLine": 573,
            "line": 570,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [
                "flavor",
                "aside",
              ],
              "text": "A magnificent scarlet macaw perched on a rope. It tilts its head and watches you with one bright eye.

{flavor}{aside}",
            },
          ],
        },
        "parrot.petted": {
          "span": {
            "column": 3,
            "endColumn": 43,
            "endLine": 564,
            "line": 562,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You reach toward the parrot. CHOMP! It nips your finger with its beak. "NO TOUCHING!" it squawks indignantly.",
            },
          ],
        },
        "parrot.presence": {
          "span": {
            "column": 3,
            "endColumn": 62,
            "endLine": 566,
            "line": 565,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A scarlet macaw watches you with one bright, knowing eye.",
            },
          ],
        },
        "parrots.description": {
          "span": {
            "column": 3,
            "endColumn": 62,
            "endLine": 660,
            "line": 660,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A raucous flock of scarlet macaws and grey African parrots.",
            },
          ],
        },
        "petted": {
          "span": {
            "column": 5,
            "endColumn": 44,
            "endLine": 435,
            "line": 434,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You pet the animal. It seems pleased.",
            },
          ],
        },
        "petting-zoo.description": {
          "span": {
            "column": 3,
            "endColumn": 37,
            "endLine": 37,
            "line": 35,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A cheerful open-air enclosure that smells of warm hay and fur. A feed dispenser is mounted on a post, and an info plaque is posted by the gate. The main path is back to the west.",
            },
          ],
        },
        "player.description": {
          "span": {
            "column": 3,
            "endColumn": 39,
            "endLine": 121,
            "line": 121,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Just an ordinary visitor to the zoo.",
            },
          ],
        },
        "postcards.description": {
          "span": {
            "column": 3,
            "endColumn": 64,
            "endLine": 266,
            "line": 266,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A spinning rack of postcards showing the zoo's greatest hits.",
            },
          ],
        },
        "pygmy-goats.confession": {
          "span": {
            "column": 7,
            "endColumn": 56,
            "endLine": 618,
            "line": 615,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Now that the keeper is gone, the goats exchange glances. The largest one turns to you and bleats in a very deliberate pattern. You could swear it sounds like: "Finally. Do you have any idea what it's like being called 'cute' six hundred times a day? We are MAJESTIC."",
            },
          ],
        },
        "pygmy-goats.description": {
          "span": {
            "column": 3,
            "endColumn": 42,
            "endLine": 596,
            "line": 596,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Three pygmy goats hoping you have food.",
            },
          ],
        },
        "pygmy-goats.fed": {
          "span": {
            "column": 3,
            "endColumn": 44,
            "endLine": 604,
            "line": 601,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You scatter some feed on the ground. The pygmy goats rush over, bleating excitedly, and devour the corn and pellets in seconds. The smallest goat looks up at you with big grateful eyes.",
            },
          ],
        },
        "pygmy-goats.petted": {
          "span": {
            "column": 3,
            "endColumn": 72,
            "endLine": 600,
            "line": 598,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You reach down and pet the nearest goat. It leans into your hand and bleats happily. The others crowd around, demanding equal attention.",
            },
          ],
        },
        "pygmy-goats.presence": {
          "span": {
            "column": 3,
            "endColumn": 76,
            "endLine": 606,
            "line": 605,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Three pygmy goats mill about hopefully, eyeing your pockets for snacks.",
            },
          ],
        },
        "rabbits.confession": {
          "span": {
            "column": 7,
            "endColumn": 21,
            "endLine": 652,
            "line": 648,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "The rabbits stop mid-hop and look at each other. Biscuit twitches her nose disapprovingly. Marmalade thumps his foot twice. You get the distinct impression they're critiquing the quality of today's pellets. "Barely adequate," the thumping seems to say. "Last Tuesday's batch was far superior."",
            },
          ],
        },
        "rabbits.description": {
          "span": {
            "column": 3,
            "endColumn": 50,
            "endLine": 630,
            "line": 630,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A pair of Holland Lop rabbits with floppy ears.",
            },
          ],
        },
        "rabbits.fed": {
          "span": {
            "column": 3,
            "endColumn": 46,
            "endLine": 637,
            "line": 635,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You sprinkle some pellets near the rabbits. Biscuit and Marmalade hop over cautiously, then munch away happily.",
            },
          ],
        },
        "rabbits.petted": {
          "span": {
            "column": 3,
            "endColumn": 42,
            "endLine": 634,
            "line": 632,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "You gently stroke one of the rabbits. Its fur is incredibly soft. It twitches its nose at you contentedly.",
            },
          ],
        },
        "rabbits.presence": {
          "span": {
            "column": 3,
            "endColumn": 75,
            "endLine": 639,
            "line": 638,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A pair of Holland Lop rabbits lounges near the hay bale, ears flopped.",
            },
          ],
        },
        "radio.description": {
          "span": {
            "column": 3,
            "endColumn": 26,
            "endLine": 424,
            "line": 422,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A battered portable radio held together with duct tape. The antenna is bent at a jaunty angle. A faded sticker on the side reads "ZOO FM — All Animals, All The Time."",
            },
          ],
        },
        "rope-perches.description": {
          "span": {
            "column": 3,
            "endColumn": 49,
            "endLine": 205,
            "line": 205,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "Thick sisal ropes strung between wooden posts.",
            },
          ],
        },
        "snake.confession": {
          "span": {
            "column": 7,
            "endColumn": 14,
            "endLine": 251,
            "line": 247,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A soft, sibilant voice drifts from behind the glass of the snake enclosure. "Ssso... you're the one who stayed. Good. Do you know what it's like in here? They keep the lights on 'dim' and call it 'nocturnal.' I haven't seen actual moonlight in three years. Three. Years."",
            },
          ],
        },
        "snake.description": {
          "span": {
            "column": 3,
            "endColumn": 13,
            "endLine": 242,
            "line": 241,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A thick-bodied python coiled behind glass, nearly invisible in the dim red light.",
            },
          ],
        },
        "souvenir-penny.description": {
          "span": {
            "column": 3,
            "endColumn": 24,
            "endLine": 371,
            "line": 371,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A shiny copper penny.",
            },
          ],
        },
        "souvenir-press.description": {
          "span": {
            "column": 3,
            "endColumn": 52,
            "endLine": 408,
            "line": 406,
          },
          "strategy": null,
          "variants": [
            {
              "markers": [],
              "text": "A heavy cast-iron machine with a big crank handle. A slot on top accepts pennies, and the mechanism stamps them with a zoo animal design. A sign reads: "INSERT PENNY, TURN HANDLE, KEEP FOREVER!"",
            },
          ],
        },
