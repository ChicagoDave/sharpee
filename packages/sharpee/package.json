{
  "name": "@sharpee/sharpee",
  "version": "1.0.8",
  "description": "Sharpee - Interactive Fiction Engine for TypeScript",
  "main": "./dist/index.js",
  "module": "./dist-esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist-esm/index.js",
      "require": "./dist/index.js",
      "esm": "./dist-esm/index.js"
    },
    "./runtime-surface": {
      "types": "./dist/runtime-surface.d.ts",
      "import": "./dist-esm/runtime-surface.js",
      "require": "./dist/runtime-surface.js",
      "esm": "./dist-esm/runtime-surface.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "clean": "rimraf dist dist-esm tsconfig.tsbuildinfo tsconfig.esm.tsbuildinfo",
    "build:npm": "tsc --outDir dist"
  },
  "dependencies": {
    "@sharpee/channel-service": "workspace:*",
    "@sharpee/core": "workspace:*",
    "@sharpee/engine": "workspace:*",
    "@sharpee/event-processor": "workspace:*",
    "@sharpee/ext-testing": "workspace:*",
    "@sharpee/if-domain": "workspace:*",
    "@sharpee/if-services": "workspace:*",
    "@sharpee/lang-en-us": "workspace:*",
    "@sharpee/media": "workspace:*",
    "@sharpee/parser-en-us": "workspace:*",
    "@sharpee/platform-browser": "workspace:*",
    "@sharpee/plugin-npc": "workspace:*",
    "@sharpee/plugin-scheduler": "workspace:*",
    "@sharpee/plugin-state-machine": "workspace:*",
    "@sharpee/plugins": "workspace:*",
    "@sharpee/character": "workspace:*",
    "@sharpee/story-runtime-baseline": "workspace:*",
    "@sharpee/stdlib": "workspace:*",
    "@sharpee/text-blocks": "workspace:*",
    "@sharpee/world-model": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "interactive-fiction",
    "if",
    "text-adventure",
    "sharpee",
    "game-engine",
    "parser",
    "zork"
  ],
  "author": "Sharpee Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChicagoDave/sharpee.git",
    "directory": "packages/sharpee"
  },
  "homepage": "https://github.com/ChicagoDave/sharpee#readme",
  "bugs": {
    "url": "https://github.com/ChicagoDave/sharpee/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "genai": {
    "entry": "./GENAI.md",
    "docs": "./docs/genai-api/"
  },
  "publishConfig": {
    "access": "public"
  }
}
